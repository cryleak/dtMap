{
  "schemaVersion": 1,
  "id": "dtmap",
  "version": "${version}",
  "name": "dtmap",
  "description": "",
  "authors": [
    "ricedotwho"
  ],
  "contact": {
    "sources": "https://github.com/ricedotwho/dtMap"
  },
  "license": "BSD 3-Clause",
  "environment": "client",
  "entrypoints": {
    "client": [
      {
        "adapter": "kotlin",
        "value": "com.ricedotwho.dtmap.DtMap"
      }
    ]
  },
  "mixins": [
    {
      "config": "dtmap.mixin.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-language-kotlin": ">=${kotlin_loader_version}",
    "fabric-api": "*",
    "minecraft": "~${minecraft_version}",
    "hypixel-mod-api": "*"
  },
  "accessWidener": "dtmap.accesswidener"
}
